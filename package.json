{
  "name": "hashmark-studio",
  "version": "0.1.0",
  "description": "Visual agent orchestration UI for hashmark",
  "type": "module",
  "bin": {
    "hashmark-studio": "dist/bin.js"
  },
  "scripts": {
    "build:server": "tsup bin.ts server/index.ts --format esm --out-dir dist --no-splitting",
    "build:client": "vite build client",
    "build": "npm run build:server && npm run build:client",
    "build:hono": "tsup bin.ts server/index.ts --format esm --out-dir dist --no-splitting",
    "dev:server": "tsup bin.ts server/index.ts --format esm --out-dir dist --watch --onSuccess \"node dist/bin.js\"",
    "dev:client": "vite client",
    "dev": "lsof -ti :3200 | xargs kill -9 2>/dev/null; npm run build:hono && HASHMARK_NO_OPEN=1 node dist/bin.js & npx wait-on -t 30000 http-get://localhost:3200/api/health && npm run dev:client",
    "tauri:dev": "lsof -ti :3200 | xargs kill -9 2>/dev/null; npm run build:hono && HASHMARK_NO_OPEN=1 node dist/bin.js & npx wait-on -t 30000 http-get://localhost:3200/api/health; npm run dev:client & npx tauri dev",
    "tauri:build": "npm run build && npx tauri build",
    "typecheck": "tsc --noEmit",
    "version:bump": "node scripts/bump-version.mjs",
    "prepare": "husky",
    "test": "cd packages/cli && npm test",
    "test:server": "vitest run --reporter=verbose server/__tests__",
    "test:watch": "cd packages/cli && npx vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@chenglou/pretext": "^0.0.4",
    "@hono/node-server": "^1.13.7",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.6.17",
    "just-bash": "^2.13.1",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "open": "^10.1.0",
    "shiki": "^4.0.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/typescript-estree": "^8.57.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  }
}
