{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hashmark studio",
  "version": "0.1.0",
  "identifier": "com.hashmark.studio",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://localhost:3201",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build:client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "hashmark studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' http://localhost:*; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; worker-src 'self' blob: http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; connect-src 'self' http://localhost:* ws://localhost:*; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
