{
  "name": "RadioGroup",
  "import": "import { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group'",
  "category": "form",
  "description": "M3 radio button group built on Radix. Circular indicators with primary fill when selected. 48px minimum touch target per item.",
  "tags": ["form", "radio", "select", "option", "group"],
  "variants": [],
  "props": {
    "value": { "type": "string", "required": false },
    "onValueChange": { "type": "(value: string) => void", "required": false },
    "defaultValue": { "type": "string", "required": false },
    "disabled": { "type": "boolean", "required": false, "default": "false" }
  },
  "example": "<RadioGroup defaultValue=\"option-a\" className=\"space-y-[var(--grid-1)]\">\n  <div className=\"flex items-center gap-[var(--grid-3)] min-h-12\">\n    <RadioGroupItem value=\"option-a\" id=\"option-a\" />\n    <label htmlFor=\"option-a\" className=\"text-[16px] leading-6 text-on-surface\">Option A</label>\n  </div>\n  <div className=\"flex items-center gap-[var(--grid-3)] min-h-12\">\n    <RadioGroupItem value=\"option-b\" id=\"option-b\" />\n    <label htmlFor=\"option-b\" className=\"text-[16px] leading-6 text-on-surface\">Option B</label>\n  </div>\n</RadioGroup>",
  "never": [
    "Never use raw <input type=\"radio\"> -- always use RadioGroup",
    "Never use Select for fewer than 5 options -- use RadioGroup instead",
    "Never make radio items shorter than 48px touch target"
  ],
  "dependencies": ["@radix-ui/react-radio-group"]
}
