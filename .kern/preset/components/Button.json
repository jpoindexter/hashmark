{
  "name": "Button",
  "import": "import { Button } from '@/components/ui/button'",
  "category": "action",
  "description": "Primary action trigger. Always use Button component, never raw <button>.",
  "tags": ["action", "submit", "trigger", "cta"],
  "variants": [
    {
      "name": "variant",
      "values": ["default", "outline", "ghost", "destructive"],
      "default": "default"
    },
    { "name": "size", "values": ["sm", "md", "lg"], "default": "md" }
  ],
  "sizes": ["sm", "md", "lg"],
  "props": {
    "variant": {
      "type": "\"default\" | \"outline\" | \"ghost\" | \"destructive\"",
      "required": false,
      "default": "default"
    },
    "size": { "type": "\"sm\" | \"md\" | \"lg\"", "required": false, "default": "md" },
    "asChild": {
      "type": "boolean",
      "required": false,
      "description": "Merge props onto child element"
    },
    "disabled": { "type": "boolean", "required": false, "default": "false" }
  },
  "example": "<Button variant=\"outline\" size=\"sm\">> SAVE CHANGES</Button>",
  "never": [
    "Never use raw <button> — always use <Button>",
    "Never hardcode colors — use variant prop",
    "Never use px/py — sizes are grid-locked via size prop"
  ],
  "dependencies": ["@radix-ui/react-slot"]
}
