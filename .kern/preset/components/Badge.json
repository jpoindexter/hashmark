{
  "name": "Badge",
  "import": "import { Badge } from '@/components/ui/badge'",
  "category": "display",
  "description": "Inline status indicator. Use for tags, statuses, and labels.",
  "tags": ["status", "tag", "label", "indicator"],
  "variants": [
    {
      "name": "variant",
      "values": ["default", "secondary", "outline", "destructive"],
      "default": "default"
    }
  ],
  "props": {
    "variant": {
      "type": "\"default\" | \"secondary\" | \"outline\" | \"destructive\"",
      "required": false,
      "default": "default"
    },
    "className": { "type": "string", "required": false }
  },
  "example": "<Badge variant=\"outline\">ACTIVE</Badge>",
  "never": [
    "Never use raw <span> for status indicators — use Badge",
    "Never hardcode badge colors — use variant prop",
    "Badge text should be UPPERCASE in Swiss-Industrial"
  ],
  "dependencies": []
}
