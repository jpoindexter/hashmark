{
  "name": "material-design",
  "version": "0.1.0",
  "description": "Rounded surfaces, tonal color system, Roboto typography, generous spacing, and pill-shaped buttons",
  "author": "Jason Poindexter",
  "kern": "0.x",
  "framework": "react",
  "styling": "tailwind",
  "components": [
    "Button",
    "Card",
    "CardHeader",
    "CardContent",
    "CardFooter",
    "Input",
    "Textarea",
    "Select",
    "Checkbox",
    "Switch",
    "RadioGroup",
    "Badge",
    "Separator",
    "Table",
    "TableHeader",
    "TableBody",
    "TableRow",
    "TableCell",
    "TableHead",
    "Form",
    "FormField",
    "FormItem",
    "FormLabel",
    "FormControl",
    "FormMessage",
    "Dialog",
    "DialogTrigger",
    "DialogContent",
    "DialogHeader",
    "DialogTitle",
    "DialogDescription",
    "Tabs",
    "TabsList",
    "TabsTrigger",
    "TabsContent"
  ],
  "aesthetic": {
    "vibe": "Expressive, adaptive, personal. Google's Material You design language.",
    "font": { "heading": "Roboto", "body": "Roboto" },
    "radius": "28px",
    "density": "comfortable",
    "contrast": "medium"
