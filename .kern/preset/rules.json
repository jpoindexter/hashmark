[
  {
    "id": "no-hardcoded-colors",
    "severity": "error",
    "forbidden": [
      "bg-gray-*",
      "bg-white",
      "bg-black",
      "text-gray-*",
      "text-white",
      "text-black",
      "text-slate-*",
      "border-gray-*",
      "text-[#hex]",
      "bg-[#hex]",
      "style={{ color: }}"
    ],
    "required": [
      "bg-surface",
      "bg-primary",
      "bg-primary-container",
      "bg-secondary-container",
      "text-foreground",
      "text-on-surface",
      "text-muted-foreground",
      "border-outline",
      "border-outline-variant"
    ],
    "fix_map": {
      "bg-gray-*": "bg-secondary-container",
      "bg-white": "bg-surface",
      "bg-black": "bg-on-surface",
      "text-gray-*": "text-muted-foreground",
      "text-white": "text-on-surface",
      "text-black": "text-foreground",
      "text-slate-*": "text-muted-foreground",
      "border-gray-*": "border-outline-variant"
    },
    "message": "Use M3 semantic color tokens (surface, on-surface, primary, primary-container, etc.). Never hardcode colors."
  },
  {
    "id": "no-raw-elements",
    "severity": "error",
    "forbidden": ["<button", "<input", "<select", "<textarea"],
    "required": ["<Button", "<Input", "<Select", "<Textarea"],
    "fix_map": {
      "<button": "<Button",
      "<input": "<Input",
      "<select": "<Select",
      "<textarea": "<Textarea"
    },
    "message": "Use components from @/components/ui/. Never use raw HTML elements for interactive controls."
  },
  {
    "id": "use-cn-utility",
    "severity": "error",
    "forbidden": ["className={`${", "className={condition ?", "className=\"base \" +"],
    "required": ["cn()", "import { cn } from '@/lib/utils'"],
    "message": "Use cn() for conditional classes. Never use string concatenation or template literals."
  },
  {
    "id": "pill-buttons",
    "severity": "warning",
    "applies_to": ["Button", "FAB", "ExtendedFAB"],
    "forbidden": [
      "rounded-lg on Button",
      "rounded-md on Button",
      "rounded-sm on Button",
      "rounded-xl on Button"
    ],
    "required": ["rounded-full"],
    "message": "Material Design 3 uses pill-shaped (fully rounded) buttons by default."
  },
  {
    "id": "tonal-elevation",
    "severity": "warning",
    "applies_to": ["Card", "Surface", "Dialog", "Sheet", "NavigationBar"],
    "forbidden": ["shadow-sm", "shadow-md", "shadow-lg", "shadow-xl", "shadow-2xl"],
    "required": ["bg-primary/5", "bg-primary/8", "bg-primary/11", "bg-primary/14"],
    "fix_map": {
      "shadow-sm": "bg-primary/5",
      "shadow-md": "bg-primary/8",
      "shadow-lg": "bg-primary/11",
      "shadow-xl": "bg-primary/14",
      "shadow-2xl": "bg-primary/14"
    },
    "message": "Use tonal elevation (bg-primary/5, bg-primary/10) instead of box shadows for M3 elevation."
  },
  {
    "id": "large-touch-targets",
    "severity": "warning",
    "applies_to": ["Button", "IconButton", "Checkbox", "Switch", "RadioGroup", "Tabs"],
    "required": ["min-h-12", "min-w-12", "48px minimum touch target"],
    "message": "Interactive elements must have a minimum 48px touch target area for M3 accessibility."
  }
]
