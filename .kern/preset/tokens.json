{
  "spacing": {
    "grid-0": "0",
    "grid-1": "4px",
    "grid-2": "8px",
    "grid-3": "12px",
    "grid-4": "16px",
    "grid-6": "24px",
    "grid-8": "32px",
    "grid-12": "48px",
    "grid-16": "64px"
  },
  "typography": {
    "display-lg": { "size": "48px", "line": "48px", "weight": 900, "transform": "uppercase" },
    "display-md": { "size": "32px", "line": "32px", "weight": 800, "transform": "uppercase" },
    "headline-lg": { "size": "24px", "line": "32px", "weight": 700, "transform": "uppercase" },
    "headline-md": { "size": "20px", "line": "32px", "weight": 700, "transform": "uppercase" },
    "body-lg": { "size": "15px", "line": "24px", "weight": 400 },
    "body-md": { "size": "13px", "line": "16px", "weight": 400 },
    "label-md": {
      "size": "10px",
      "line": "16px",
      "weight": 700,
      "transform": "uppercase",
      "tracking": "0.1em"
    },
    "caption": { "size": "11px", "line": "16px", "weight": 400 }
  },
  "colors": {
    "semantic": [
      "background",
      "foreground",
      "card",
      "card-foreground",
      "muted",
      "muted-foreground",
      "border",
      "input",
      "ring",
      "primary",
      "primary-foreground",
      "secondary",
      "secondary-foreground",
      "accent",
      "accent-foreground",
      "popover",
      "popover-foreground",
      "destructive",
      "destructive-foreground",
      "success",
      "warning",
      "info"
    ],
    "forbidden": ["gray-*", "slate-*", "zinc-*", "white", "black", "any hex/rgb/hsl"]
  },
  "sizing": {
    "button-sm": "24px",
    "button-md": "32px",
    "input": "24px",
    "icon-sm": "16px",
    "icon-md": "16px",
    "icon-lg": "24px",
    "badge-sm": "16px",
    "badge-md": "24px",
    "global-bar": "48px"
  },
  "radius": "0px",
  "font": "monospace"
}
