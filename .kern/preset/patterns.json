[
  {
    "name": "page-header",
    "description": "Standard page header with title, description, and actions",
    "tags": ["header", "page", "title", "actions", "navigation"],
    "components": ["Button", "Separator"],
    "code": "<div className=\"flex items-center justify-between h-[var(--grid-12)]\">\n  <div>\n    <h1 className={mode.typography.headline.lg}>PAGE_TITLE</h1>\n    <p className={cn(mode.typography.body.md, \"text-muted-foreground\")}>\n      Description text here\n    </p>\n  </div>\n  <div className=\"flex gap-[var(--grid-2)]\">\n    <Button variant=\"outline\" size=\"sm\">> ACTION</Button>\n    <Button size=\"sm\">> PRIMARY</Button>\n  </div>\n</div>\n<Separator />",
    "layout": {
      "structure": "single-column",
      "maxWidth": "full",
      "spacing": "var(--grid-6)"
    },
    "type": "section"
  },
  {
    "name": "settings-section",
    "description": "Card-based form section for settings pages with grouped inputs",
    "tags": ["settings", "preferences", "configuration", "form", "profile", "account"],
    "components": [
      "Card",
      "CardHeader",
      "CardContent",
      "Form",
      "FormField",
      "FormItem",
      "FormLabel",
      "FormControl",
      "FormMessage",
      "Input",
      "Button"
    ],
    "code": "<Card className={cn(\"border border-border\", mode.radius)}>\n  <CardHeader code=\"0x01\" title=\"SECTION_TITLE\" />\n  <CardContent padding=\"md\">\n    <Form {...form}>\n      <form onSubmit={form.handleSubmit(onSubmit)} className=\"space-y-[var(--grid-4)]\">\n        <FormField\n          control={form.control}\n          name=\"fieldName\"\n          render={({ field }) => (\n            <FormItem>\n              <FormLabel>FIELD LABEL</FormLabel>\n              <FormControl>\n                <Input placeholder=\"Placeholder\" {...field} />\n              </FormControl>\n              <FormMessage />\n            </FormItem>\n          )}\n        />\n        <Button type=\"submit\">> SAVE CHANGES</Button>\n      </form>\n    </Form>\n  </CardContent>\n</Card>",
    "layout": {
      "structure": "single-column",
      "maxWidth": "2xl",
      "spacing": "var(--grid-6)"
    },
    "type": "form",
    "client_required": true,
    "client_reason": "Form uses react-hook-form which requires client-side state"
  },
  {
    "name": "data-table",
    "description": "Table with sortable headers, pagination, and row actions",
    "tags": ["table", "data", "list", "sortable", "pagination", "rows"],
    "components": ["Table", "TableHeader", "TableBody", "TableRow", "TableCell", "Button", "Badge"],
    "code": "<div className=\"border border-border\">\n  <Table>\n    <TableHeader>\n      <TableRow>\n        <TableHead>COLUMN</TableHead>\n        <TableHead>STATUS</TableHead>\n        <TableHead className=\"text-right\">ACTIONS</TableHead>\n      </TableRow>\n    </TableHeader>\n    <TableBody>\n      {data.map((row) => (\n        <TableRow key={row.id}>\n          <TableCell className={mode.typography.body.md}>{row.name}</TableCell>\n          <TableCell><Badge variant=\"outline\">{row.status}</Badge></TableCell>\n          <TableCell className=\"text-right\">\n            <Button variant=\"ghost\" size=\"sm\">> EDIT</Button>\n          </TableCell>\n        </TableRow>\n      ))}\n    </TableBody>\n  </Table>\n</div>",
    "layout": {
      "structure": "full-width",
      "spacing": "var(--grid-4)"
    },
    "type": "data"
  },
  {
    "name": "empty-state",
    "description": "Empty state with icon, message, and call-to-action",
    "tags": ["empty", "placeholder", "no-data", "onboarding", "zero-state"],
    "components": ["Card", "Button"],
    "code": "<Card className={cn(\"flex flex-col items-center justify-center p-[var(--grid-16)] text-center\", mode.radius)}>\n  <div className=\"mb-[var(--grid-4)]\">\n    <IconPlaceholder className=\"h-[var(--grid-12)] w-[var(--grid-12)] text-muted-foreground\" />\n  </div>\n  <h3 className={mode.typography.headline.md}>NO DATA YET</h3>\n  <p className={cn(mode.typography.body.md, \"text-muted-foreground mt-[var(--grid-2)]\")}>Description of what to do next</p>\n  <Button className=\"mt-[var(--grid-6)]\">> GET STARTED</Button>\n</Card>",
    "layout": {
      "structure": "centered",
      "spacing": "var(--grid-4)"
    },
    "type": "section"
  },
  {
    "name": "dashboard-card",
    "description": "Metric card with label, value, and optional trend indicator",
    "tags": ["dashboard", "metric", "stats", "kpi", "card", "analytics"],
    "components": ["Card", "CardHeader", "CardContent", "Badge"],
    "code": "<Card className={cn(\"border border-border\", mode.radius)}>\n  <CardHeader className=\"flex flex-row items-center justify-between p-[var(--grid-4)]\">\n    <span className={mode.typography.label}>METRIC LABEL</span>\n    <Badge variant=\"outline\">+12%</Badge>\n  </CardHeader>\n  <CardContent className=\"p-[var(--grid-4)] pt-0\">\n    <div className={mode.typography.display.md}>1,234</div>\n    <p className={cn(mode.typography.caption, \"text-muted-foreground\")}>vs. previous period</p>\n  </CardContent>\n</Card>",
    "layout": {
      "structure": "grid",
      "spacing": "var(--grid-4)"
    },
    "type": "data"
  }
]
