# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Postgres — Supabase or Neon)
DATABASE_URL=postgresql://user:password@localhost:5432/hashmark

# Auth (GitHub OAuth App — https://github.com/settings/developers)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# Polar.sh (https://polar.sh — Settings > Developers > Access Tokens)
# Use sandbox token for local dev, production token for prod
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=whsec_...
POLAR_PRO_PRODUCT_ID=prod_...
POLAR_TEAM_PRODUCT_ID=prod_...

# GitHub Webhook (set in repo Settings > Webhooks > Secret)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Hashmark CLI (optional — override path to CLI binary for production)
# HASHMARK_CLI_PATH=/app/packages/cli/dist/cli.js
