# hashmark studio — environment variables
# Copy to .env.local and fill in values

# Studio server port (default: 3200)
# HASHMARK_PORT=3200

# Disable auto-opening the browser on dev server start
# HASHMARK_NO_OPEN=1

# Initial project directory (set by the app, usually not needed manually)
# HASHMARK_PROJECT_DIR=/path/to/project

# --- AI Provider Keys (optional — studio uses CLI auth by default) ---

# Anthropic API key (for Claude provider)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (for Codex/GPT providers)
# OPENAI_API_KEY=sk-...

# Google AI API key (for Gemini provider)
# GOOGLE_API_KEY=...
