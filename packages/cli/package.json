{
  "name": "hashmark-cli",
  "version": "2.0.0",
  "description": "Scan your codebase and generate AI context files for every coding tool",
  "type": "module",
  "bin": {
    "hashmark": "dist/cli.js",
    "agent-smith": "dist/cli.js",
    "agentsmith": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsup src/cli.ts --format esm --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "sync-version": "./scripts/sync-version.sh",
    "prebuild": "./scripts/sync-version.sh"
  },
  "keywords": [
    "hashmark",
    "ai",
    "agents",
    "agents.md",
    "claude.md",
    "cursorrules",
    "copilot",
    "windsurf",
    "gemini",
    "context",
    "cli",
    "codebase",
    "llm",
    "cursor",
    "claude"
  ],
  "author": "Jason Poindexter",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jpoindexter/hashmark.git",
    "directory": "packages/cli"
  },
  "homepage": "https://hashmark.md",
  "bugs": {
    "url": "https://github.com/jpoindexter/hashmark/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@typescript-eslint/typescript-estree": "^8.54.0",
    "cac": "^6.7.14",
    "clipboardy": "^5.2.1",
    "fast-glob": "^3.3.0",
    "graphql": "^16.12.0",
    "picocolors": "^1.1.0",
    "ts-morph": "^27.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
