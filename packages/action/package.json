{
  "name": "hashmark-action",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action: One scan. Every format. Always in sync.",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --no-splitting",
    "dev": "tsup src/index.ts --format esm --target node20 --watch"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  }
}
